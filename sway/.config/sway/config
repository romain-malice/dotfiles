# Set wallpaper and colorscheme
#exec "./scripts/wallpaper.sh"
#include "~/.cache/wal/colors-sway"
output * bg "/usr/share/backgrounds/default.jxl" fill

# Notification daemon
exec mako

########
# Idle #
########

exec swayidle -w timeout 300 'swaymsg "output * power off"' resume 'swaymsg "output * power on"'
exec swayidle -w timeout 300 "swaylock -f -i $wallpaper"
exec swayidle -w timeout 1800 "swaymsg 'output * power on'"
exec swayidle -w timeout 1800 'systemctl suspend'
exec swayidle before-sleep "swaylock -f -i $wallpaper"

# Include modules
include "./config.d/*"

# Color temperature adjustement
exec gammastep -l 50.64:5.57 -t 5700:3600 -g 0.8 -m wayland

# Disable laptop screen
bindsym $mod+d exec swaymsg output eDP-1 disable
bindsym $mod+Shift+d exec swaymsg output eDP-1 enable
