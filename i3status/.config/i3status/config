general {
    output_format = "none"
    colors = true
    interval = 5
}

order += "wireless _first_"
order += "volume master"
order += "battery 0"
order += time

wireless _first_ {
    format_up = "󰖩  %essid (%quality)"
    format_down = "󰖪 "
}

volume master {
    format = "󰕾  %volume"
    format_muted = "󰖁 "
    device = "pulse"
}

battery 0 {
    format = "%status %percentage"
    status_chr = "󰂀"
    status_bat = "󰂀"
    status_full = "󱈑"
    last_full_capacity = true
    integer_battery_capacity = true
    low_threshold = 20
    threshold_type = percentage
    path = "/sys/class/power_supply/BATT/uevent"
}

time {
    format = "%A %-d %B  %H:%M"
}
